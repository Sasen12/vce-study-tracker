generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String              @unique
  passwordHash   String              @map("password_hash")
  displayName    String              @map("display_name")
  schoolName     String?             @map("school_name")
  avatarUrl      String?             @map("avatar_url")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  subjects       UserSubject[]
  sessions       StudySession[]
  events         Event[]
  goals          Goal[]
  gamification   UserGamification?
  savedQuestions SavedQuestion[]
  reflections    StudyReflection[]
  notes          StudyNote[]
  resources      StudyResource[]
  plans          AdaptiveStudyPlan[]
  feedbackItems  UserFeedback[]
  chatMessages   CommunityChatMessage[]
  giftMessages   UserGiftMessage[]
  usageEvents    UserUsageEvent[]
  memoryEvents   StudentMemoryEvent[]
  learningSignals LearningSignal[]
  subjectMemories StudentSubjectMemory[]

  @@map("users")
}

model UserSubject {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String            @map("user_id") @db.Uuid
  subjectName String            @map("subject_name")
  unit        String
  targetScore Int?              @map("target_score")
  color       String
  archivedAt  DateTime?         @map("archived_at") @db.Timestamptz(6)
  archivedReason String?        @map("archived_reason")
  supersededBySubjectId String? @map("superseded_by_subject_id") @db.Uuid
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    StudySession[]
  events      Event[]
  goals       Goal[]
  questions   SavedQuestion[]
  reflections StudyReflection[]
  notes       StudyNote[]
  resources   StudyResource[]
  memoryEvents StudentMemoryEvent[]
  learningSignals LearningSignal[]
  subjectMemories StudentSubjectMemory[]

  @@index([userId])
  @@index([userId, archivedAt])
  @@map("user_subjects")
}

model StudySession {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  subjectId       String?      @map("subject_id") @db.Uuid
  durationSeconds Int          @map("duration_seconds")
  notes           String?
  xpEarned        Int          @default(0) @map("xp_earned")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subjectId])
  @@map("study_sessions")
}

model Event {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  subjectId   String?      @map("subject_id") @db.Uuid
  title       String
  eventType   String       @map("event_type")
  eventDate   DateTime     @map("event_date") @db.Date
  startTime   String?      @map("start_time")
  endTime     String?      @map("end_time")
  recurrence  String       @default("NONE")
  recurrenceUntil DateTime? @map("recurrence_until") @db.Date
  notificationMinutes Int   @default(60) @map("notification_minutes")
  source      String       @default("manual")
  googleCalendarId String? @map("google_calendar_id")
  googleEventId String?    @map("google_event_id")
  description String?
  completed   Boolean      @default(false)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, eventDate])
  @@map("events")
}

model Goal {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  subjectId         String?      @map("subject_id") @db.Uuid
  targetStudyScore  Int?         @map("target_study_score")
  weeklyHoursTarget Decimal?     @map("weekly_hours_target") @db.Decimal(4, 1)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject           UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([userId, subjectId])
  @@map("goals")
}

model UserGamification {
  userId            String    @id @map("user_id") @db.Uuid
  totalXp           Int       @default(0) @map("total_xp")
  xpBalance         Int       @default(0) @map("xp_balance")
  level             Int       @default(1)
  currentStreak     Int       @default(0) @map("current_streak")
  longestStreak     Int       @default(0) @map("longest_streak")
  lastStudyDate     DateTime? @map("last_study_date") @db.Date
  badges            Json      @default("[]")
  unlockedCosmetics Json      @default("[\"midnight\"]") @map("unlocked_cosmetics")
  activeTheme       String    @default("midnight") @map("active_theme")
  activeTitle       String    @default("vce_rookie") @map("active_title")
  leaderboardOptIn  Boolean   @default(false) @map("leaderboard_opt_in")
  leaderboardPromptedAt DateTime? @map("leaderboard_prompted_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_gamification")
}

model SavedQuestion {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String       @map("user_id") @db.Uuid
  subjectId       String?      @map("subject_id") @db.Uuid
  question        String
  modelAnswer     String       @map("model_answer")
  topic           String?
  difficulty      String?
  marks           Int?
  markingCriteria Json         @default("[]") @map("marking_criteria")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject         UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subjectId])
  @@map("saved_questions")
}

model StudyReflection {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  subjectId    String?      @map("subject_id") @db.Uuid
  classDate    DateTime     @map("class_date") @db.Date
  classSummary String       @map("class_summary")
  understood   String
  confused     String
  nextAction   String?      @map("next_action")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, classDate])
  @@index([subjectId])
  @@map("study_reflections")
}

model StudyNote {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  subjectId String?      @map("subject_id") @db.Uuid
  title     String
  body      String
  noteType  String       @default("general") @map("note_type")
  tags      Json         @default("[]")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([subjectId])
  @@map("study_notes")
}

model StudyResource {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  subjectId     String?      @map("subject_id") @db.Uuid
  fileName      String       @map("file_name")
  fileType      String       @map("file_type")
  sourceType    String       @default("textbook") @map("source_type")
  extractedText String       @map("extracted_text")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subjectId])
  @@map("study_resources")
}

model AdaptiveStudyPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  planDate        DateTime @map("plan_date") @db.Date
  summary         String
  focusAreas      Json     @default("[]") @map("focus_areas")
  tasks           Json     @default("[]")
  dailyPlan       Json     @default("[]") @map("daily_plan")
  subjectRoadmaps Json     @default("[]") @map("subject_roadmaps")
  sourceEvents    Json     @default("[]") @map("source_events")
  checkpoints     Json     @default("[]")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("adaptive_study_plans")
}

model UserFeedback {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  category  String
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("user_feedback")
}

model CommunityChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("community_chat_messages")
}

model UserGiftMessage {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  title     String
  message   String
  giftType  String    @map("gift_type")
  giftId    String    @map("gift_id")
  readAt    DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("user_gift_messages")
}

model UserUsageEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  screen    String
  action    String   @default("view")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([screen, createdAt])
  @@index([userId, createdAt])
  @@map("user_usage_events")
}

model StudentMemoryEvent {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  subjectId  String?          @map("subject_id") @db.Uuid
  eventType  String           @map("event_type")
  sourceType String           @map("source_type")
  sourceId   String?          @map("source_id")
  title      String
  summary    String
  payload    Json             @default("{}")
  importance Int              @default(1)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject    UserSubject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  signals    LearningSignal[]

  @@index([userId, createdAt])
  @@index([subjectId, createdAt])
  @@index([eventType, createdAt])
  @@map("student_memory_events")
}

model LearningSignal {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String              @map("user_id") @db.Uuid
  subjectId     String?             @map("subject_id") @db.Uuid
  subjectKey    String              @map("subject_key")
  subjectName   String              @map("subject_name")
  memoryEventId String?             @map("memory_event_id") @db.Uuid
  signalType    String              @map("signal_type")
  topic         String?
  title         String
  detail        String
  evidence      String
  confidence    String              @default("medium")
  nextAction    String?             @map("next_action")
  weight        Int                 @default(1)
  sourceType    String              @map("source_type")
  sourceId      String?             @map("source_id")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       UserSubject?        @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  memoryEvent   StudentMemoryEvent? @relation(fields: [memoryEventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([subjectKey, createdAt])
  @@index([signalType, createdAt])
  @@index([memoryEventId])
  @@map("learning_signals")
}

model StudentSubjectMemory {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  subjectId           String?      @map("subject_id") @db.Uuid
  subjectKey          String       @map("subject_key")
  subjectName         String       @map("subject_name")
  strengths           Json         @default("[]")
  weakAreas           Json         @default("[]") @map("weak_areas")
  commonMistakes      Json         @default("[]") @map("common_mistakes")
  recentTopics        Json         @default("[]") @map("recent_topics")
  upcomingAssessments Json         @default("[]") @map("upcoming_assessments")
  bestStudyMethods    Json         @default("[]") @map("best_study_methods")
  evidenceTrail       Json         @default("[]") @map("evidence_trail")
  riskLevel           String       @default("low") @map("risk_level")
  predictedNextTask   String?      @map("predicted_next_task")
  createdAt           DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  user                User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject             UserSubject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([userId, subjectKey])
  @@index([userId, riskLevel])
  @@index([subjectId])
  @@map("student_subject_memory")
}
