{
  "name": "vce-study-tracker-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema src/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema src/db/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema src/db/prisma/schema.prisma",
    "grant:theme": "tsx src/scripts/grantTheme.ts",
    "smtp:check": "npm run build && node dist/scripts/checkSmtp.js",
    "digest:send": "npm run build && node dist/scripts/sendWeeklyDigest.js",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "openai": "^6.34.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.20.0",
    "word-extractor": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.12",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "prisma": "^6.19.3",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx src/db/seed.ts"
  }
}
