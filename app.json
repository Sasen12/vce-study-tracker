{
  "expo": {
    "name": "VCE Forge",
    "slug": "vce-study-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vcestudy",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F0F14"
      }
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
